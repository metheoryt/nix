// Reference pyright config tuned for GORTEX RESOLUTION QUALITY.
//
// Gortex's real Python resolver is the lsp-pyright provider, so "align a repo
// for gortex" == "make it resolve cleanly under pyright." Copy this to the
// repo root as pyrightconfig.json (or fold the keys into [tool.pyright] in
// pyproject.toml). Pyright parses this file as JSONC, so // comments are fine.
//
// Two halves below:
//   (A) RESOLUTION KNOBS  - actually change what pyright/gortex can resolve.
//   (B) GAP DIAGNOSTICS   - don't change resolution, but flag every spot that
//                           would otherwise become a weak `text_matched` edge,
//                           so a human/agent can fix it and feed the resolver.
{
  // ---- (A) RESOLUTION KNOBS ------------------------------------------------

  // Pin to the interpreter the project actually runs, so stdlib/feature
  // resolution matches reality.
  "pythonVersion": "3.13",

  // Point pyright at the venv that has the project's deps INSTALLED. Without a
  // resolvable env, every third-party import is unresolved and every call
  // through it degrades to text_matched in gortex. Adjust to your layout
  // (or use "pythonPath": ".venv/bin/python").
  "venvPath": ".",
  "venv": ".venv",

  // Source roots and noise. Keep migrations/build artifacts out so the graph
  // isn't polluted with generated code.
  "include": ["src", "app"],
  "exclude": [
    "**/__pycache__",
    "**/node_modules",
    ".venv",
    "build",
    "dist",
    "**/migrations"
  ],

  // THE single most important resolution knob: when a dependency ships no type
  // stubs, infer types from its SOURCE instead of giving up. Turning this off
  // is the most common cause of un-stubbed libraries resolving to Any (and thus
  // text_matched gortex edges).
  "useLibraryCodeForTypes": true,

  // Baseline preset. We keep "standard" so a repo can adopt this without
  // drowning in day-one errors, then ratchet to "strict" once the gaps below
  // are paid down. "strict" is the end-goal — it turns most of (B) into errors.
  "typeCheckingMode": "standard",

  // ---- (B) GAP DIAGNOSTICS -------------------------------------------------
  // Each of these flags a place gortex cannot resolve a real type. Fixing them
  // (annotate, or install stubs) is what upgrades text_matched -> lsp_resolved.

  // Unresolved imports / missing stubs. reportMissingTypeStubs is the nudge to
  // `pip install django-stubs djangorestframework-stubs types-*` — installed
  // stubs lift Django managers/querysets/model fields out of the guess tier.
  "reportMissingImports": "error",
  "reportMissingModuleSource": "warning",
  "reportMissingTypeStubs": "warning",
  "reportAttributeAccessIssue": "error",

  // Missing annotations — every untyped surface is an unresolved edge for gortex.
  "reportMissingParameterType": "error",
  "reportUntypedBaseClass": "error",
  "reportUntypedNamedTuple": "error",
  "reportUntypedFunctionDecorator": "warning",
  "reportUntypedClassDecorator": "warning",

  // Inferred-Any spots — these are EXACTLY the calls/members that become
  // text_matched. Warnings (not errors) so they're visible without blocking.
  "reportUnknownParameterType": "warning",
  "reportUnknownArgumentType": "warning",
  "reportUnknownVariableType": "warning",
  "reportUnknownMemberType": "warning",
  "reportUnknownLambdaType": "warning",

  // Explicit Any is a resolution dead-end. (Requires a recent pyright; remove
  // these two keys if your pyright is old enough to warn they're unknown.)
  "reportAny": "warning",
  "reportExplicitAny": "warning",

  // Import hygiene that keeps the symbol graph clean and statically traceable.
  "reportPrivateImportUsage": "warning",
  "reportWildcardImportFromLibrary": "warning",
  "reportImplicitOverride": "warning"
}
